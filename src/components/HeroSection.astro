---
interface Props {
  title: string;
  subtitle: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const { title, subtitle, ctaLabel, ctaHref, secondaryLabel, secondaryHref } = Astro.props;
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <h1>{title}</h1>
      <p class="hero__subtitle">{subtitle}</p>
      {(ctaLabel || secondaryLabel) && (
        <div class="hero__actions">
          {ctaLabel && ctaHref && (
            <a href={ctaHref} class="btn btn-primary">{ctaLabel}</a>
          )}
          {secondaryLabel && secondaryHref && (
            <a href={secondaryHref} class="btn btn-outline">{secondaryLabel}</a>
          )}
        </div>
      )}
    </div>
    <div class="hero__decoration" aria-hidden="true">
      <div class="hero__circle hero__circle--1"></div>
      <div class="hero__circle hero__circle--2"></div>
      <div class="hero__emblem">
        <span>LF</span>
        <small>Praha</small>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    color: var(--color-white);
    padding: var(--space-20) 0;
    overflow: hidden;
    position: relative;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: var(--space-12);
  }

  .hero__content h1 {
    color: var(--color-white);
    margin-bottom: var(--space-4);
  }

  .hero__subtitle {
    color: rgba(255,255,255,0.8);
    font-size: 1.125rem;
    line-height: 1.7;
    margin-bottom: var(--space-8);
    max-width: 48ch;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hero__decoration {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 300px;
  }

  .hero__circle {
    position: absolute;
    border-radius: 50%;
    border: 2px solid rgba(74,144,217,0.3);
  }

  .hero__circle--1 {
    width: 260px;
    height: 260px;
  }

  .hero__circle--2 {
    width: 180px;
    height: 180px;
    border-color: rgba(74,144,217,0.5);
  }

  .hero__emblem {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 120px;
    height: 120px;
    background: rgba(74,144,217,0.15);
    border: 2px solid var(--color-accent);
    border-radius: 50%;
  }

  .hero__emblem span {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-white);
    line-height: 1;
  }

  .hero__emblem small {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }

    .hero__decoration {
      display: none;
    }
  }
</style>
